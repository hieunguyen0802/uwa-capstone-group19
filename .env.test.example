# Shared test environment defaults.
POSTGRES_DB=workload_test_db
POSTGRES_USER=test_admin
POSTGRES_PASSWORD=test_password_change_me

# Use different host ports from local dev.
DB_PORT=55433

# Shared pgAdmin account for test environment.
PGADMIN_DEFAULT_EMAIL=test-admin@workload.com
PGADMIN_DEFAULT_PASSWORD=test_admin_change_me
PGADMIN_PORT=55050

# Test env email defaults (OTP emails appear in backend logs).
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@workload.test
