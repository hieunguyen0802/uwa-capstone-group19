POSTGRES_DB=workload_db
POSTGRES_USER=admin
POSTGRES_PASSWORD=password

# Host port used by PostgreSQL container.
DB_PORT=5433

# Optional pgAdmin container account.
PGADMIN_DEFAULT_EMAIL=admin@workload.com
PGADMIN_DEFAULT_PASSWORD=admin123
PGADMIN_PORT=5050

# Email delivery defaults (dev: print OTP emails in backend logs).
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@workload.local
